<section
  class="tour-dates"
  data-section-id="{{ section.id }}"
  data-section-type="tour-dates">
  <div class="page-width">

    {%- if section.settings.tour_flyer != blank -%}
      <div class="tour-dates__flyer">
        <div class="tour-dates__flyer-wrapper">
          {%- assign img_url = section.settings.tour_flyer | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}
          <img class="tour-dates__flyer-image lazyload"
            data-src="{{ img_url }}"
            data-widths="[180, 360, 540, 750, 900, 1080]"
            data-aspectratio="{{ section.settings.tour_flyer.aspect_ratio }}"
            data-sizes="auto"
            alt="{{ section.settings.tour_flyer.alt }}"
            role="presentation">
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <div class="tour-dates__title">
        <header class="section-header">
          <h1 class="section-header__title">{{ section.settings.title }}</h1>
        </header>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="tour-dates__dates">

        {%- for block in section.blocks -%}
            <div class="tour-dates__date">

              {%- if block.settings.title != blank -%}
                <div class="tour-dates__date-date">
                  {{ block.settings.title }}
                </div>
              {%- endif -%}

              {%- if block.settings.location != blank -%}
                <div class="tour-dates__date-location{%- if block.settings.venue == blank -%} tour-dates__date-location--full{%- endif -%}">
                  {{ block.settings.location }}
                </div>
              {%- endif -%}

              {%- if block.settings.venue != blank -%}
                <div class="tour-dates__date-venue">
                  {{ block.settings.venue }}
                </div>
              {%- endif -%}

              {%- if block.settings.button_1_text != blank or block.settings.button_1_url != blank or block.settings.button_2_text != blank or block.settings.button_2_url != blank -%}
                <div class="tour-dates__date-buttons">

                  {%- if block.settings.button_1_text != blank or block.settings.button_1_url != blank -%}
                    <a href="{{ block.settings.button_1_url }}" class="btn btn--secondary" target="_blank">{{ block.settings.button_1_text }}</a>
                  {%- endif -%}

                  {%- if block.settings.button_2_text != blank or block.settings.button_2_url != blank -%}
                    <a href="{{ block.settings.button_2_url }}" class="btn btn--secondary" target="_blank">{{ block.settings.button_2_text }}</a>
                  {%- endif -%}

                </div>
              {%- endif -%}

            </div>
        {%- endfor -%}

      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Tour dates",
  "class": "tour-dates-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "tour_flyer",
      "label": "Tour flyer"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    }
  ],
  "blocks": [
    {
      "type": "tour_date",
      "name": "Tour date",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Date"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location"
        },
        {
          "type": "text",
          "id": "venue",
          "label": "Venue"
        },
        {
          "type": "text",
          "id": "button_1_text",
          "label": "Button 1 text"
        },
        {
          "type": "url",
          "id": "button_1_url",
          "label": "Button 1 URL"
        },
        {
          "type": "text",
          "id": "button_2_text",
          "label": "Button 2 text"
        },
        {
          "type": "url",
          "id": "button_2_url",
          "label": "Button 2 URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tour dates"
    }
  ]
}
{% endschema %}