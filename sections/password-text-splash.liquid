<section
  class="password-text-splash"
  data-section-id="{{ section.id }}"
  data-section-type="password-text-splash">
  <header class="password-text-splash__header">
    <div class="page-width">
      <div class="password-text-splash__logo">
        <h1 itemscope itemtype="http://schema.org/Organization" class="h2">
          {%- if section.settings.logo != blank -%}
            {%- assign header_logo_size = section.settings.desktop_logo_height | prepend: 'x' -%}
            {%- assign header_logo_size_mobile = section.settings.mobile_logo_height | prepend: 'x' -%}
            {%- style -%}
              .password-text-splash__logo h1 {
                height: {{ section.settings.mobile_logo_height }}px;
              }
              @media only screen and (min-width: 769px) {
                .password-text-splash__logo h1 {
                  height: {{ section.settings.desktop_logo_height }}px;
                }
              }
            {%- endstyle -%}
            <img
              class="small--hide"
              src="{{ section.settings.logo | img_url: header_logo_size }}"
              srcset="{{ section.settings.logo | img_url: header_logo_size }} 1x, {{ section.settings.logo | img_url: header_logo_size, scale: 2 }} 2x"
              alt="{{ section.settings.logo.alt | default: shop.name }}"
              itemprop="logo">
            <img
              class="medium-up--hide"
              src="{{ section.settings.logo | img_url: header_logo_size_mobile }}"
              srcset="{{ section.settings.logo | img_url: header_logo_size_mobile }} 1x, {{ section.settings.logo | img_url: header_logo_size_mobile, scale: 2 }} 2x"
              alt="{{ section.settings.logo.alt | default: shop.name }}">
          {%- else -%}
            <span>{{ shop.name }}</span>
          {%- endif -%}
        </h1>
      </div>
    </div>
  </header>
  <main class="password-text-splash__main">
    <div class="page-width">
      <div class="password-text-splash__main-content">
        {%- if section.settings.main_message != blank -%}
          <div class="password-text-splash__main-message">
            {{ section.settings.main_message }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </main>
  <footer class="password-text-splash__footer">
    <div class="page-width">
      {%- if section.settings.footer_message != blank -%}
        <div class="password-text-splash__footer-message">
          {{ section.settings.footer_message }}
        </div>
      {%- endif -%}
    </div>
  </footer>
</section>

{% schema %}
{
  "name": "Password text splash",
  "class": "password-text-splash-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Main logo"
    },
    {
      "type": "range",
      "id": "desktop_logo_height",
      "label": "Desktop logo height",
      "default": 50,
      "min": 20,
      "max": 120,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "mobile_logo_height",
      "label": "Mobile logo height",
      "default": 50,
      "min": 20,
      "max": 120,
      "unit": "px"
    },
    {
      "type": "richtext",
      "id": "main_message",
      "label": "Main message",
      "default": "<p>Website is currently closed.</p>"
    },
    {
      "type": "richtext",
      "id": "capture_message",
      "label": "Capture message",
      "default": "<p>Enter your mobile number to be the first to know about the next collection release.</p>"
    },
    {
      "type": "richtext",
      "id": "agree_message",
      "label": "Agree message",
      "default": "<p>Agree to <a href=\"http://attn.tv/4hunnid/terms.html\" target=\"blank\">Terms</a> & <a href=\"https://attnl.tv/p/g4j\" target=\"blank\">Privacy</a>.</p>"
    },
    {
      "type": "richtext",
      "id": "footer_message",
      "label": "Footer message",
      "default": "<p>Lorem ipsum dolor sit amet, consetetur sadipscing elitr, sed diam nonumy eirmod.</p>"
    }
  ],
  "presets": [
    {
      "name": "Password text splash"
    }
  ]
}
{% endschema %}