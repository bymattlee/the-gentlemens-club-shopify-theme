{%- liquid
  assign video_id = ''
  if section.settings.video_url != blank
    if section.settings.video_url.type == 'youtube'
      assign video_id = section.settings.video_url.id
    endif
  endif
-%}

{%- if video_id != blank and section.settings.cover_image != blank -%}
  <div
    class="full-width-video"
    data-section-id="{{ section.id }}"
    data-section-type="full-width-video"
    data-video-id="{{ video_id | escape }}"
  >
    <div class="full-width-video__frame">
      <div class="full-width-video__embed" data-full-width-video-embed></div>

      <div class="full-width-video__overlay">
        {%- assign img_url = section.settings.cover_image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}
        <img
          class="full-width-video__poster-image lazyload"
          src=""
          data-src="{{ img_url }}"
          data-widths="[375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840]"
          data-aspectratio="{{ section.settings.cover_image.aspect_ratio }}"
          data-sizes="auto"
          alt="{{ section.settings.cover_image.alt | escape }}"
          width="{{ section.settings.cover_image.width }}"
          height="{{ section.settings.cover_image.height }}"
        >
        <noscript>
          <img
            class="full-width-video__poster-image"
            src="{{ section.settings.cover_image | img_url: '2000x' }}"
            alt="{{ section.settings.cover_image.alt | escape }}"
            width="{{ section.settings.cover_image.width }}"
            height="{{ section.settings.cover_image.height }}"
          >
        </noscript>

        <button
          type="button"
          class="full-width-video__trigger"
          data-full-width-video-trigger
          aria-label="Play video"
        >
          <span class="full-width-video__watch">
            <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-play full-width-video__watch-icon" viewBox="18.24 17.35 24.52 28.3"><path fill="currentColor" d="M22.1 19.151v25.5l20.4-13.489-20.4-12.011z"/></svg>
            <span class="full-width-video__watch-label">Watch</span>
          </span>
        </button>
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Full-width video",
  "class": "index-section index-section--flush full-width-video-section",
  "settings": [
    {
      "type": "video_url",
      "id": "video_url",
      "label": "YouTube video",
      "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
      "accept": ["youtube"]
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Video screenshot"
    }
  ],
  "presets": [
    {
      "name": "Full-width video"
    }
  ]
}
{% endschema %}
