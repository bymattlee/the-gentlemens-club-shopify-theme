<div
  class="product-benefits product-benefits--{{ section.settings.size }}"
  data-section-id="{{ section.id }}"
  data-section-type="text-with-icons"
>
  <div class="page-width">
    <div class="product-benefits__items">

      {%- for block in section.blocks -%}
        <div class="product-benefits__item">
          <div class="product-benefits__item-icon">

            {%- case block.settings.icon -%}
              {%- when 'lock' -%}
                <svg class="product-benefits__item-icon-svg" aria-hidden="true" focusable="false" role="presentation" viewBox="0 0 40 41">
                  <path d="M30.9 15.9c-.5-.5-1.2-.8-1.9-.8h-2.3v-3.3c0-1.9-.6-3.4-1.9-4.7s-2.9-2-4.8-2-3.4.6-4.7 1.9-1.9 2.9-1.9 4.7V15H11a2.732 2.732 0 0 0-2.7 2.7v14.6A2.732 2.732 0 0 0 11 35h18a2.732 2.732 0 0 0 2.7-2.7V17.8c0-.7-.3-1.3-.8-1.9zM15 11.8c0-1.4.5-2.6 1.5-3.5s2.2-1.5 3.5-1.5 2.6.5 3.5 1.5c1 1 1.5 2.2 1.5 3.5v3.3H15v-3.3zm15 20.6c0 .3-.1.5-.3.7-.2.2-.4.3-.7.3H11c-.3 0-.5-.1-.7-.3-.2-.1-.3-.4-.3-.7V17.8c0-.3.1-.5.3-.7.2-.2.4-.3.7-.3h18c.3 0 .5.1.7.3.2.2.3.4.3.7v14.6z"/>
                  <path d="M20.8 24.3v-5h-1.6v5h-5V26h5v5h1.6v-5h5v-1.7z"/>
                </svg>
              {%- when 'globe' -%}
                <svg class="product-benefits__item-icon-svg" aria-hidden="true" focusable="false" role="presentation" viewBox="0 0 40 41">
                  <path d="M20 35.1c-2.1 0-4-.4-5.9-1.2-1.8-.8-3.4-1.9-4.8-3.2C8 29.4 7 27.8 6.2 26 5.4 24.2 5 22.2 5 20.1s.4-4 1.2-5.9C7 12.5 8 10.9 9.4 9.5c1.4-1.4 2.9-2.4 4.8-3.2 1.8-.8 3.7-1.2 5.8-1.2 2.1 0 4 .4 5.9 1.2 1.8.8 3.4 1.9 4.8 3.2 1.4 1.4 2.4 2.9 3.2 4.8.8 1.8 1.2 3.8 1.2 5.8s-.4 4-1.2 5.9c-.8 1.8-1.9 3.4-3.2 4.8-1.4 1.4-2.9 2.4-4.8 3.2-1.9.7-3.8 1.1-5.9 1.1zm-1.7-1.7v-3.2c-.9 0-1.7-.3-2.4-1-.6-.6-1-1.5-1-2.4v-1.7l-8-8c-.1.5-.2 1-.2 1.5-.1.5-.1 1-.1 1.5 0 3.4 1.1 6.3 3.3 8.8 2.3 2.6 5.1 4.1 8.4 4.5zm11.5-4.3c.6-.6 1.1-1.3 1.5-2 .4-.7.8-1.4 1.1-2.2.3-.8.5-1.5.7-2.4.2-.8.2-1.6.2-2.5 0-2.7-.8-5.2-2.3-7.5-1.5-2.3-3.5-3.9-6.1-4.9v.7c0 .9-.3 1.7-1 2.4-.6.6-1.5 1-2.4 1h-3.3V15c0 .5-.2.9-.5 1.2-.3.3-.7.5-1.2.5h-3.3V20h10c.5 0 .9.2 1.2.5s.5.7.5 1.2v5h1.7c.7 0 1.4.2 2 .6.6.6 1 1.1 1.2 1.8z"/>
                </svg>
              {%- when 'refund' -%}
                <svg class="product-benefits__item-icon-svg" aria-hidden="true" focusable="false" role="presentation" viewBox="0 0 40 41">
                  <path d="M20 36.8c-3.4 0-6.4-.9-9.1-2.7-2.7-1.8-4.7-4.2-6-7.3v5.5H3.2V24h8.3v1.7H6.2c1.1 2.9 2.9 5.1 5.4 6.9 2.5 1.7 5.3 2.6 8.4 2.6 2 0 3.9-.4 5.6-1.1 1.7-.7 3.3-1.7 4.6-3 1.3-1.3 2.4-2.8 3.3-4.5.8-1.7 1.3-3.6 1.4-5.6h1.7c-.1 2.2-.6 4.3-1.5 6.2-.9 1.9-2.1 3.6-3.6 5s-3.2 2.6-5.2 3.4c-2 .8-4.1 1.2-6.3 1.2zm-.9-5.6v-2c-1.1-.3-2.1-.7-2.9-1.4-.8-.6-1.4-1.5-1.9-2.7l1.5-.6c.5 1 1.1 1.8 1.9 2.4.8.6 1.7.8 2.6.8 1 0 1.9-.3 2.8-.8.9-.5 1.3-1.4 1.3-2.5 0-.9-.3-1.7-.9-2.2-.6-.5-1.8-1.1-3.6-1.8-1.8-.6-3.1-1.3-3.8-2.1-.8-.7-1.1-1.7-1.1-2.9 0-1 .4-1.9 1.1-2.8s1.9-1.4 3.3-1.6V9H21v2c.9.1 1.7.4 2.4.9s1.3 1.2 1.7 2l-1.4.6c-.3-.6-.8-1.1-1.4-1.5-.6-.4-1.3-.6-2.1-.6-1.1 0-2 .3-2.6.9-.7.6-1 1.3-1 2.1s.3 1.5.8 2 1.7 1 3.5 1.7c2 .7 3.4 1.5 4.1 2.3.7.8 1.1 1.8 1.1 3 0 .8-.2 1.5-.5 2.1-.3.6-.7 1.1-1.2 1.5-.5.4-1 .7-1.6.9-.6.2-1.2.3-1.8.4v2h-1.9v-.1zM3.4 19.3c.1-2.3.7-4.4 1.6-6.4s2.2-3.6 3.7-5 3.3-2.5 5.2-3.3c2-.8 4.1-1.2 6.2-1.2 3.3 0 6.4.9 9.1 2.7s4.8 4.3 6 7.4V8h1.7v8.3h-8.3v-1.7h5.3c-1-2.8-2.8-5-5.3-6.8C26 6 23.1 5.1 20 5.1c-1.9 0-3.7.3-5.5 1-1.7.7-3.3 1.7-4.7 2.9-1.4 1.2-2.5 2.7-3.3 4.5-.9 1.7-1.4 3.7-1.5 5.8H3.4z" />
                </svg>
              {%- when 'box'-%}
                <svg class="product-benefits__item-icon-svg" aria-hidden="true" focusable="false" role="presentation" viewBox="0 0 40 41">
                  <path d="M19.2 33V20.6L8.3 14.3v11.8c0 .2 0 .3.1.5.1.1.2.3.4.4l10.4 6zm1.6 0 10.3-6c.2-.1.3-.2.4-.4.1-.1.1-.3.1-.5V14.3l-10.8 6.3V33zm-2.1 1.6L8 28.5c-.4-.2-.8-.6-1-1-.2-.4-.4-.9-.4-1.3v-12c0-.5.1-.9.4-1.3.2-.4.6-.7 1-1l10.6-6.1c.4-.2.9-.4 1.3-.4s.9.1 1.3.4l10.8 6c.4.2.8.6 1 1 .2.4.4.9.4 1.3v12c0 .5-.1.9-.4 1.3-.2.4-.6.8-1 1l-10.6 6.1c-.5.4-.9.5-1.4.5s-.9-.1-1.3-.4zm7.5-19 4.5-2.6-10.2-5.9c-.1-.1-.3-.2-.5-.2s-.4.1-.5.2l-4 2.3 10.7 6.2zM20 19.2l4.5-2.6-10.7-6.2L9.3 13 20 19.2z" />
              </svg>
            {%- endcase -%}

          </div>

          {%- if block.settings.title != blank or block.settings.description != blank -%}
            <div class="product-benefits__item-text">

              {%- if block.settings.title != blank -%}
                <div class="product-benefits__item-title">
                  <h3>{{ block.settings.title }}</h3>
                </div>
              {%- endif -%}

              {%- if block.settings.description != blank and section.settings.size != 'compact' -%}
                <div class="product-benefits__item-description">
                  {{ block.settings.description }}
                </div>
              {%- endif -%}

            </div>
          {%- endif -%}

        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product benefits",
  "class": "index-section",
  "settings": [
    {
      "type": "select",
      "id": "size",
      "label": "Size",
      "default": "default",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "compact",
          "label": "Compact"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "lock",
          "options": [
            {
              "value": "lock",
              "label": "Lock"
            },
            {
              "value": "globe",
              "label": "Globe"
            },
            {
              "value": "refund",
              "label": "Refund"
            },
            {
              "value": "box",
              "label": "Box"
            }
          ]
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Benefit title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Nam liber tempor cum soluta nobis eleifend option congue nihil imperdiet doming id quod mazim placerat facer possim assum.</p>",
          "info": "Will be hidden if the size is set to 'compact'."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product benefits",
      "blocks": [
        {
          "type": "benefit"
        },
        {
          "type": "benefit"
        },
        {
          "type": "benefit"
        },
        {
          "type": "benefit"
        }
      ]
    }
  ]
}
{% endschema %}