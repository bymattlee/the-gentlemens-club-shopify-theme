<section
  class="video-autoplay"
  data-section-id="{{ section.id }}"
  data-section-type="video-autoplay">
  <div class="page-width">
    {%- if section.settings.video_url -%}
      <div class="video-autoplay__container">
        <div class="video-autoplay__video-container">
          <video src="{{ section.settings.video_url }}" class="video-autoplay__video" autoplay loop muted playsinline preload></video>
          <button class="video-autoplay__sound-toggle" type="button">
            <svg viewBox="0 0 74 65" class="video-autoplay__sound-toggle-svg video-autoplay__sound-toggle-svg--on">
              <path d="M44 65 22 43H0V22h22L44 0v65z"/>
              <path d="m58.2 59.2-2.5-4.3c.5-.3 11.7-7.1 11.7-22.3 0-15.2-11.2-21-11.6-21.3L58 6.8c.6.3 14.4 7.4 14.4 25.7.1 18.2-13.6 26.3-14.2 26.7z"/>
              <path d="m52.2 50.2-2.5-4.4c.3-.2 6.7-4 6.7-12.8s-6.5-12.7-6.7-12.8l2.5-4.4c.4.2 9.3 5.4 9.3 17.2s-8.9 17-9.3 17.2z"/>
            </svg>
            <svg viewBox="0 0 74 65" class="video-autoplay__sound-toggle-svg video-autoplay__sound-toggle-svg--off">
              <path d="M44 65 22 43H0V22h22L44 0v65z"/>
              <path d="m65.1 33.1 7.7-9-3.8-3.2-7.4 8.6-7.8-8.2-3.6 3.4 8.2 8.6-8.2 9.6 3.8 3.2 7.8-9.1 8.4 8.7 3.6-3.4z"/>
            </svg>
          </button>
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Video autoplay",
  "class": "video-autoplay-section",
  "settings": [
    {
      "type": "url",
      "id": "video_url",
      "label": "Video url",
      "info": "Format: .mp4"
    }
  ],
  "presets": [
    {
      "name": "Video autoplay"
    }
  ]
}
{% endschema %}