<script src="https://a.klaviyo.com/media/js/onsite/onsite.js"></script>
<script>
    var klaviyo = klaviyo || [];
    var additionalStyles = '#container{border-radius:0;text-transform:uppercase;line-height:1.2;} .form-control{background-color:transparent;border:1px solid {{ settings.color_borders | default: \"#1c1d1d\" }};color:{{ settings.color_body_text | default: \"#1c1d1d\" }};border-radius:0;box-shadow: none;}.btn{font-size:12px;text-transform:uppercase;padding:12px 24px;line-height:1.2;}.alert{margin:0;padding:0;}';
    klaviyo.init({
      account: "TdnQEp",
      list: 'TnqKia',
      platform: "shopify"
    });
    klaviyo.enable("backinstock",{ 
    trigger: {
      product_page_text: "Notify Me When Available",
      product_page_class: "btn btn--full",
      product_page_text_align: "center",
      product_page_margin: "0px",
      replace_anchor: true
    },
    modal: {
     headline: "{product_name}",
     body_content: "Register to receive a notification when this item comes back in stock.",
     email_field_label: "Email",
     button_label: "Notify me when available",
     subscription_success_label: "You're in! We'll let you know when it's back.",
     footer_content: '',
     newsletter_subscribe_label: "Add me to your email list.",
     subscribe_checked: true,
     additional_styles: additionalStyles,
     drop_background_color: "#000",
     background_color: "{{ settings.color_body_bg | default: \"#fff\" }}",
     text_color: "{{ settings.color_body_text | default: \"#1c1d1d\" }}",
     button_text_color: "{{ settings.color_button_text | default: \"#fff\" }}",
     button_background_color: "{{ settings.color_button | default: \"#000\" }}",
     close_button_color: "{{ settings.color_body_text | default: \"#1c1d1d\" }}",
     error_background_color: "{{ settings.color_body_bg | default: \"#fff\" }}",
     error_text_color: "{{ settings.color_body_text | default: \"#1c1d1d\" }}",
     success_background_color: "{{ settings.color_body_bg | default: \"#fff\" }}",
     success_text_color: "{{ settings.color_body_text | default: \"#1c1d1d\" }}"
    }
  });
</script>