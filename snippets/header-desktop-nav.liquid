{%- liquid
  unless limit
    assign limit = main_menu.links.size
  endunless
  unless offset
    assign offset = 0
  endunless
-%}

<ul
  class="site-nav site-navigation small--hide"
  {% unless disable_aria %}
    role="navigation" aria-label="Primary"
  {% endunless %}>
  {%- comment %}<locksmith:dcf6>{% endcomment -%}
    {%- assign locksmith_b4b5_forloop__size = 0 %}{%- for link in main_menu.links limit: limit offset: offset -%}{% capture var %}{% render 'locksmith-variables', scope: 'subject', subject: link, subject_parent: main_menu, variable: 'transparent' %}{% endcapture %}{% if var == 'true' %}{% assign locksmith_b4b5_forloop__size = locksmith_b4b5_forloop__size | plus: 1 %}{% endif %}{% endfor %}{% assign locksmith_b4b5_forloop__index = nil -%}
  {%- comment %}</locksmith:dcf6>{% endcomment -%}
  {%- for link in main_menu.links limit: limit offset: offset -%}
    {%- comment %}<locksmith:961a>{% endcomment -%}
      {%- capture var %}{% render 'locksmith-variables', scope: 'subject', subject: link, subject_parent: main_menu, variable: 'transparent' %}{% endcapture %}{% if var == "true" %}{% if locksmith_b4b5_forloop__index == nil %}{% assign locksmith_b4b5_forloop__index = 1 %}{% assign locksmith_b4b5_forloop__index0 = 0 %}{% else %}{% assign locksmith_b4b5_forloop__index = locksmith_b4b5_forloop__index | plus: 1 %}{% assign locksmith_b4b5_forloop__index0 = locksmith_b4b5_forloop__index0 | plus: 1 %}{% endif %}{% if locksmith_b4b5_forloop__index == 1 %}{% assign locksmith_b4b5_forloop__first = true %}{% else %}{% assign locksmith_b4b5_forloop__first = false %}{% endif %}{% if locksmith_b4b5_forloop__index == locksmith_b4b5_forloop__size %}{% assign locksmith_b4b5_forloop__last = true %}{% else %}{% assign locksmith_b4b5_forloop__last = false %}{% endif %}{% assign locksmith_b4b5_forloop__rindex = locksmith_b4b5_forloop__size | minus: locksmith_b4b5_forloop__index | minus: 1 %}{% assign locksmith_b4b5_forloop__rindex0 = locksmith_b4b5_forloop__size | minus: locksmith_b4b5_forloop__index0 | minus: 1 %}{% else %}{% continue %}{% endif -%}
    {%- comment %}</locksmith:961a>{% endcomment -%}
    {%- liquid
      assign has_dropdown = false
      assign is_megamenu = false
      if link.links != blank
        assign has_dropdown = true
        if link.levels > 1
          assign is_megamenu = true
        endif
      endif
    -%}

    <li
      class="site-nav__item site-nav__expanded-item{% if has_dropdown %} site-nav--has-dropdown{% endif %}{% if is_megamenu %} site-nav--is-megamenu{% endif %}"
      {% if has_dropdown %}aria-haspopup="true"{% endif %}>

      <a href="{{ link.url }}" class="site-nav__link{% if link.active %} site-nav__link--active{% endif %}{% if has_dropdown %} site-nav__link--has-dropdown{% endif %}">
        {{ link.title }}
      </a>
      {%- if is_megamenu -%}
        {%- assign previous_column_type = '' -%}
        {%- assign animation_column = 1 -%}

        <div class="site-nav__dropdown megamenu text-left">
          <div class="page-width">
            <div class="grid{% if dropdown_alignment == 'center' %} grid--center{% endif %}">
              <div class="grid__item medium-up--one-fifth appear-animation appear-delay-{{ animation_column }}">
                {%- assign animation_column = animation_column | plus: 1 -%}

                {%- comment %}<locksmith:ef0c>{% endcomment -%}
                  {%- assign locksmith_5009_forloop__size = 0 %}{%- for childlink in link.links -%}{% capture var %}{% render 'locksmith-variables', scope: 'subject', subject: childlink, subject_parent: link, variable: 'transparent' %}{% endcapture %}{% if var == 'true' %}{% assign locksmith_5009_forloop__size = locksmith_5009_forloop__size | plus: 1 %}{% endif %}{% endfor %}{% assign locksmith_5009_forloop__index = nil -%}
                {%- comment %}</locksmith:ef0c>{% endcomment -%}
                {%- for childlink in link.links -%}
                  {%- comment %}<locksmith:5f4f>{% endcomment -%}
                    {%- capture var %}{% render 'locksmith-variables', scope: 'subject', subject: childlink, subject_parent: link, variable: 'transparent' %}{% endcapture %}{% if var == "true" %}{% if locksmith_5009_forloop__index == nil %}{% assign locksmith_5009_forloop__index = 1 %}{% assign locksmith_5009_forloop__index0 = 0 %}{% else %}{% assign locksmith_5009_forloop__index = locksmith_5009_forloop__index | plus: 1 %}{% assign locksmith_5009_forloop__index0 = locksmith_5009_forloop__index0 | plus: 1 %}{% endif %}{% if locksmith_5009_forloop__index == 1 %}{% assign locksmith_5009_forloop__first = true %}{% else %}{% assign locksmith_5009_forloop__first = false %}{% endif %}{% if locksmith_5009_forloop__index == locksmith_5009_forloop__size %}{% assign locksmith_5009_forloop__last = true %}{% else %}{% assign locksmith_5009_forloop__last = false %}{% endif %}{% assign locksmith_5009_forloop__rindex = locksmith_5009_forloop__size | minus: locksmith_5009_forloop__index | minus: 1 %}{% assign locksmith_5009_forloop__rindex0 = locksmith_5009_forloop__size | minus: locksmith_5009_forloop__index0 | minus: 1 %}{% else %}{% continue %}{% endif -%}
                  {%- comment %}</locksmith:5f4f>{% endcomment -%}
                  {%- liquid
                    assign create_new_column = false

                    if childlink.levels > 0 and locksmith_5009_forloop__index != 1
                      assign create_new_column = true
                    endif

                    if childlink.levels == 0 and previous_column_type == 'full'
                      assign create_new_column = true
                    endif
                  -%}

                  {%- if create_new_column -%}
                    </div><div class="grid__item medium-up--one-fifth appear-animation appear-delay-{{ animation_column }}">
                    {%- assign animation_column = animation_column | plus: 1 -%}
                  {%- endif -%}

                  {%- if childlink.levels > 0 and childlink.url contains '/collections/' -%}
                    {%- if collections[childlink.object.handle].image != blank -%}
                      <a
                        href="{{ childlink.url }}"
                        class="megamenu__colection-image"
                        aria-label="{{collections[childlink.object.handle].title}}"
                        style="background-image: url({{ collections[childlink.object.handle].image | img_url: '400x' }})"></a>
                    {%- endif -%}
                  {%- endif -%}

                  <div class="h5">
                    <a href="{{ childlink.url }}" class="site-nav__dropdown-link site-nav__dropdown-link--top-level">{{ childlink.title }}</a>
                  </div>

                  {%- liquid
                    if childlink.levels > 0
                      assign previous_column_type = 'full'
                    else
                      assign previous_column_type = 'single'
                    endif
                  -%}

                  {%- for grandchildlink in childlink.links -%}
                    {%- comment %}<locksmith:080a>{% endcomment -%}
                      {%- capture var %}{% render 'locksmith-variables', scope: 'subject', subject: grandchildlink, subject_parent: childlink, variable: 'transparent' %}{% endcapture %}{% if var == "true" %}{% else %}{% continue %}{% endif -%}
                    {%- comment %}</locksmith:080a>{% endcomment -%}
                    <div>
                      <a href="{{ grandchildlink.url }}" class="site-nav__dropdown-link">
                        {{grandchildlink.title}}
                      </a>
                    </div>
                  {%- endfor -%}
                {%- endfor -%}
              </div>
            </div>
          </div>
        </div>
      {%- elsif has_dropdown -%}
        <div class="site-nav__dropdown-container">
          <ul class="site-nav__dropdown">
            {%- for childlink in link.links -%}
              {%- comment %}<locksmith:e688>{% endcomment -%}
                {%- capture var %}{% render 'locksmith-variables', scope: 'subject', subject: childlink, subject_parent: link, variable: 'transparent' %}{% endcapture %}{% if var == "true" %}{% else %}{% continue %}{% endif -%}
              {%- comment %}</locksmith:e688>{% endcomment -%}
              {%- liquid
                assign has_sub_dropdown = false
                if childlink.links != blank
                  assign has_sub_dropdown = true
                endif
              -%}

              <li class="{% if has_sub_dropdown %} site-nav__deep-dropdown-trigger{% endif %}">
                <a href="{{ childlink.url }}" class="site-nav__dropdown-link site-nav__dropdown-link--second-level{% if has_sub_dropdown %} site-nav__dropdown-link--has-children{% endif %}{% if childlink.active %} site-nav__link--active{% endif %}">
                  {{ childlink.title | escape }}
                  {%- if has_sub_dropdown -%}
                    <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon--wide icon-chevron-down" viewBox="0 0 28 16"><path d="M1.57 1.59l12.76 12.77L27.1 1.59" stroke-width="2" stroke="#000" fill="none" fill-rule="evenodd"/></svg>
                  {%- endif -%}
                </a>
                {%- if has_sub_dropdown -%}
                  <ul class="site-nav__deep-dropdown">
                    {%- for grandchildlink in childlink.links -%}
                      {%- comment %}<locksmith:f181>{% endcomment -%}
                        {%- capture var %}{% render 'locksmith-variables', scope: 'subject', subject: grandchildlink, subject_parent: childlink, variable: 'transparent' %}{% endcapture %}{% if var == "true" %}{% else %}{% continue %}{% endif -%}
                      {%- comment %}</locksmith:f181>{% endcomment -%}
                      <li>
                        <a href="{{ grandchildlink.url }}" class="site-nav__dropdown-link">{{ grandchildlink.title | escape }}</a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    </li>
  {%- endfor -%}
</ul>
