{
  "name": "the-gentlemens-club-shopify-theme",
  "version": "1.0.0",
  "private": true,
  "description": "The Gentlemen's Club Shopify theme by Matt Lee.",
  "scripts": {
    "dev": "shopify theme dev --store=theegentlemensclub.myshopify.com",
    "pull": "shopify theme pull --store=theegentlemensclub.myshopify.com",
    "pull-dev": "shopify theme pull -d --store=theegentlemensclub.myshopify.com",
    "push": "shopify theme push --store=theegentlemensclub.myshopify.com",
    "auth-logout": "shopify auth logout"
  }
}
