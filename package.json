{
  "name": "4hunnid-shopify-theme",
  "version": "1.0.0",
  "private": true,
  "description": "4Hunnid Shopify theme by Matt Lee.",
  "scripts": {
    "dev": "shopify theme dev --store=4hunnid-original.myshopify.com",
    "pull": "shopify theme pull --store=4hunnid-original.myshopify.com",
